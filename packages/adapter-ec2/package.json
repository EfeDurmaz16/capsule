{
  "name": "@capsule/adapter-ec2",
  "version": "0.1.1",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm && tsc -p tsconfig.json --emitDeclarationOnly",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-ec2": "^3.955.0",
    "@capsule/core": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.5.0",
    "typescript": "^5.9.3"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "description": "Amazon EC2 adapter for Capsule machine lifecycle primitives.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/EfeDurmaz16/capsule.git",
    "directory": "packages/adapter-ec2"
  },
  "homepage": "https://github.com/EfeDurmaz16/capsule#readme",
  "bugs": {
    "url": "https://github.com/EfeDurmaz16/capsule/issues"
  },
  "keywords": [
    "capsule",
    "ec2",
    "adapter",
    "runtime",
    "deployment"
  ],
  "engines": {
    "node": ">=20.11"
  }
}
