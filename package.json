{
  "name": "capsule",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "build": "pnpm -r build",
    "test": "vitest run",
    "typecheck": "tsc -b",
    "lint": "tsc -b --pretty false",
    "changeset": "changeset",
    "version-packages": "changeset version && pnpm install --lockfile-only",
    "release": "pnpm typecheck && pnpm test && pnpm build && pnpm release:audit && changeset publish",
    "release:audit": "pnpm release:metadata-audit && pnpm release:markers && pnpm release:pack-smoke",
    "release:metadata-audit": "node scripts/package-publish-audit.mjs",
    "release:markers": "node scripts/no-unfinished-markers.mjs",
    "release:pack-smoke": "node scripts/package-pack-smoke.mjs",
    "docs:api": "node scripts/generate-api-reference.mjs",
    "capsule:gap": "node scripts/capsule-gap-report.mjs",
    "capsule:issues": "node scripts/create-github-issues.mjs",
    "capsule:linear": "node scripts/create-linear-issues.mjs",
    "capsule:autopilot": "node scripts/capsule-autopilot.mjs",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@types/node": "^24.10.0",
    "tsup": "^8.5.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^4.0.14"
  }
}
